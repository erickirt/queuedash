{
  "name": "@queuedash/api",
  "version": "3.18.0",
  "description": "A stunning, sleek dashboard for Bull, BullMQ, and Bee-Queue",
  "scripts": {
    "build": "tsc && vite build",
    "dev": "pnpm run build --watch",
    "test": "pnpm run test:bull && pnpm run test:bullmq && pnpm run test:bee && pnpm run test:groupmq",
    "test:bull": "QUEUE_TYPE=bull vitest run",
    "test:bullmq": "QUEUE_TYPE=bullmq vitest run",
    "test:bee": "QUEUE_TYPE=bee vitest run",
    "test:groupmq": "QUEUE_TYPE=groupmq vitest run",
    "lint": "oxlint --config ../../.oxlintrc.json --disable-nested-config .",
    "lint:fix": "oxlint --config ../../.oxlintrc.json --disable-nested-config --fix .",
    "format": "oxfmt --config ../../.oxfmtrc.json .",
    "format:check": "oxfmt --config ../../.oxfmtrc.json --check ."
  },
  "main": "./dist/main.js",
  "module": "./dist/main.mjs",
  "types": "./dist/src/main.d.ts",
  "files": [
    "dist"
  ],
  "keywords": [
    "bull",
    "bee-queue",
    "queue",
    "bullmq",
    "dashboard"
  ],
  "dependencies": {
    "@trpc/server": "^11.14.1",
    "redis": "^4.7.0",
    "redis-info": "^3.1.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@hono/trpc-server": "^0.3.0",
    "bee-queue": "^1.0.0",
    "bull": "^3.0.0 || ^4.0.0",
    "bullmq": "^1.0.0 || ^5.0.0",
    "elysia": "^1.0.0",
    "express": "^4.0.0 || ^5.0.0",
    "fastify": "^4.0.0 || ^5.0.0",
    "groupmq": "^1.0.0",
    "hono": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@hono/trpc-server": {
      "optional": true
    },
    "bee-queue": {
      "optional": true
    },
    "bull": {
      "optional": true
    },
    "bullmq": {
      "optional": true
    },
    "elysia": {
      "optional": true
    },
    "express": {
      "optional": true
    },
    "fastify": {
      "optional": true
    },
    "groupmq": {
      "optional": true
    },
    "hono": {
      "optional": true
    }
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@hono/trpc-server": "^0.3.4",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/express": "^5.0.6",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/node": "^24.8.1",
    "@types/redis-info": "^3.0.3",
    "bee-queue": "^1.7.1",
    "bull": "^4.16.5",
    "bullmq": "^5.71.0",
    "elysia": "^1.4.28",
    "express": "^5.2.1",
    "fastify": "^5.8.2",
    "groupmq": "^1.1.0",
    "hono": "^4.12.8",
    "ioredis": "^5.10.1",
    "memoirist": "^0.4.0",
    "rollup-plugin-typescript-paths": "^1.5.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.19",
    "vitest": "^3.2.4"
  },
  "license": "MIT"
}
