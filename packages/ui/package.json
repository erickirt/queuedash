{
  "name": "@queuedash/ui",
  "version": "3.19.0",
  "description": "A stunning, sleek dashboard for Bull, BullMQ, and Bee-Queue",
  "main": "./dist/main.js",
  "module": "./dist/main.mjs",
  "types": "./dist/src/main.d.ts",
  "files": [
    "dist"
  ],
  "keywords": [
    "bull",
    "bee-queue",
    "queue",
    "bullmq",
    "dashboard"
  ],
  "scripts": {
    "build": "tsc && vite build && npx @tailwindcss/cli -i src/styles/global.css -o ./dist/styles.css",
    "dev": "pnpm run build --watch",
    "tailwind": "npx @tailwindcss/cli -i src/styles/global.css -o ./dist/styles.css --watch",
    "lint": "oxlint --config ../../.oxlintrc.json --disable-nested-config .",
    "lint:fix": "oxlint --config ../../.oxlintrc.json --disable-nested-config --fix .",
    "format": "oxfmt --config ../../.oxfmtrc.json .",
    "format:check": "oxfmt --config ../../.oxfmtrc.json --check ."
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@queuedash/api": "workspace:*",
    "@tanstack/react-query": "^5.94.5",
    "@tanstack/react-table": "^8.21.3",
    "@trpc/client": "^11.14.1",
    "@trpc/react-query": "^11.14.1",
    "@trpc/server": "^11.14.1",
    "clsx": "^2.1.1",
    "cronstrue": "^3.14.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "lucide-react": "^0.577.0",
    "monaco-editor": "^0.55.1",
    "react-aria-components": "^1.16.0",
    "react-intersection-observer": "^10.0.3",
    "react-json-tree": "^0.20.0",
    "react-router": "^7.13.1",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.3.0",
    "@tailwindcss/cli": "^4.2.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rollup-plugin-typescript-paths": "^1.5.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^5.4.19"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "license": "MIT"
}
